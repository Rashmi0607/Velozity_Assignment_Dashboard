generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String
  name          String
  role          String         // ADMIN, PM, DEVELOPER
  avatar        String?
  projects      Project[]      @relation("ProjectManager")
  tasks         Task[]         @relation("TaskAssignee")
  activityLogs  ActivityLog[]
  notifications Notification[]
  createdAt     DateTime       @default(now())
}

model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  status      String   @default("ACTIVE") // ACTIVE, COMPLETED, ON_HOLD
  managerId   String
  manager     User     @relation("ProjectManager", fields: [managerId], references: [id])
  tasks       Task[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Task {
  id          String   @id @default(uuid())
  title       String
  description String?
  status      String   @default("BACKLOG") // BACKLOG, IN_PROGRESS, REVIEW, DONE
  priority    String   @default("MEDIUM")  // LOW, MEDIUM, HIGH, URGENT
  dueDate     DateTime
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  assigneeId  String?
  assignee    User?    @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String   // e.g., "TASK_UPDATED", "PROJECT_CREATED"
  details   String
  timestamp DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      String   @default("INFO") // INFO, WARNING, SUCCESS, ERROR
  read      Boolean  @default(false)
  timestamp DateTime @default(now())
}
